# API Configuration
# NOTE: API URL is automatically configured in src/services/api.js based on platform:
# - iOS Simulator: http://localhost:8080/api
# - Android Emulator: http://10.0.2.2:8080/api
# 
# Only uncomment below if you need to override for physical device or production:

# For Physical Device (replace with your computer's IP)
# Find your IP with: ifconfig | grep "inet " | grep -v 127.0.0.1
# API_BASE_URL=http://192.168.1.100:8080/api

# For Production
# API_BASE_URL=https://your-production-api.com/api
